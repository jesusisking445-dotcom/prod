# ==============================================================
# HomoDentHealth — Environment Variables
# ==============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in EVERY value marked with YOUR_ or REPLACE_
# 3. NEVER commit your real .env — it is in .gitignore
# ==============================================================

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
SERVE_FRONTEND=false

# ── MongoDB Atlas ───────────────────────────────────────────────
# Create a free cluster at https://cloud.mongodb.com
# IMPORTANT: Add your server IP to the Atlas IP Access List
#            (Network Access → Add IP → Allow from Anywhere for Render)
MONGODB_URI=mongodb+srv://YOUR_ATLAS_USER:YOUR_ATLAS_PASSWORD@cluster0.xxxxx.mongodb.net/homodenthealth?retryWrites=true&w=majority

# ── JWT Secrets ─────────────────────────────────────────────────
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX_STRING
REFRESH_TOKEN_EXPIRE=30d

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your deployed frontend URL here alongside localhost.
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,https://YOUR_FRONTEND_DOMAIN.com

# ── Frontend URL (used inside email links) ──────────────────────
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN.com

# ── Email (Gmail SMTP) ──────────────────────────────────────────
# IMPORTANT: Use a 16-character App Password — NOT your Gmail password.
# Enable at: https://myaccount.google.com/apppasswords
# (Requires 2-Factor Authentication to be turned on first)
#
# SMTP_FROM must match SMTP_USER when using Gmail — do NOT use a custom
# domain here unless you have configured Gmail Send-As for that domain.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_GMAIL_ADDRESS@gmail.com
SMTP_PASS=YOUR_16_CHAR_APP_PASSWORD
SMTP_FROM=YOUR_GMAIL_ADDRESS@gmail.com

# ── Alternative: Brevo (free 300 emails/day, custom From domain) ─
# Sign up at https://brevo.com → SMTP & API → Generate SMTP key
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=YOUR_BREVO_LOGIN_EMAIL
# SMTP_PASS=YOUR_BREVO_SMTP_KEY
# SMTP_FROM=noreply@homodenthealth.ng

# ── Twilio SMS (optional — appointment reminders via SMS) ────────
# Sign up at https://twilio.com — free trial available
# Without these, SMS reminders are silently skipped (email still works)
TWILIO_ACCOUNT_SID=AC_PLACEHOLDER_REPLACE_WITH_REAL_SID
TWILIO_AUTH_TOKEN=PLACEHOLDER_REPLACE_WITH_REAL_TOKEN
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── WhatsApp / Termii (optional) ────────────────────────────────
TERMII_API_KEY=YOUR_TERMII_API_KEY
TERMII_SECRET_KEY=YOUR_TERMII_SECRET_KEY
TERMII_SENDER_ID=HomoDentHealth

# ── File uploads ────────────────────────────────────────────────
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ── Security ────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=900000

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=info
